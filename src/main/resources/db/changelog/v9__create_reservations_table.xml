<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="javafag">
        <createTable tableName="reservations">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="customer_email" type="varchar(255)"/>
            <column name="customer_phone" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="reservation_time" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="guest_count" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="special_requests" type="varchar(500)"/>
            <column name="dining_table_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="reservations"
            baseColumnNames="dining_table_id"
            referencedTableName="tables"
            referencedColumnNames="id"
            constraintName="fk_reservation_table"
            onDelete="CASCADE"
            onUpdate="CASCADE"/>
    </changeSet>

</databaseChangeLog>
