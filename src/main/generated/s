Given-When-Then Pattern:

java
@Test
@DisplayName("Успешное создание заказа")
void should_CreateOrder_WhenRequestIsValid() {
    // Given (Дано) - подготовка данных
    OrderRequestDto request = OrderRequestDto.builder()
        .drinkName("Latte")
        .price(5.0)
        .build();

    when(repository.save(any(Order.class))).thenReturn(savedOrder);

    // When (Когда) - выполнение действия
    OrderResponseDto response = service.createOrder(request);

    // Then (Тогда) - проверка результатов
    assertEquals("Latte", response.getDrinkName());
    verify(repository, times(1)).save(any(Order.class));
}
