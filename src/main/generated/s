3.4 WireMock - мокирование внешних API
WireMock для имитации внешних сервисов:

java
@SpringBootTest
class PaymentServiceTest {

    @RegisterExtension
    static WireMockExtension wireMock = WireMockExtension.newInstance()
        .options(WireMockConfiguration.options().port(8089))
        .build();

    @Test
    void should_ProcessPayment_WhenExternalApiResponds() {
        // Настройка мока
        wireMock.stubFor(post(urlEqualTo("/api/payments"))
            .willReturn(aResponse()
                .withStatus(200)
                .withHeader("Content-Type", "application/json")
                .withBody("{\"status\":\"success\",\"transactionId\":\"123\"}")));

        // Тест
        PaymentResult result = paymentService.processPayment(paymentRequest);

        // Проверки
        assertEquals("success", result.getStatus());
        wireMock.verify(postRequestedFor(urlEqualTo("/api/payments")));
    }
}
